# ============================================================================
# ForkCast environment variables
# Copy to `.env` for local dev (`netlify dev` loads it automatically), and set
# the same keys under Site settings → Environment variables on Netlify.
# ============================================================================

# --- Session signing (REQUIRED) --------------------------------------------
# Any long random string. Generate one: `openssl rand -hex 32`
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google OAuth SSO (REQUIRED for login) ---------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
#   • OAuth consent screen: External, add the "userinfo.email" + "openid" scopes
#   • Authorized redirect URI (local):  http://localhost:8888/api/auth-google/callback
#   • Authorized redirect URI (prod):   https://YOUR-SITE.netlify.app/api/auth-google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin (REQUIRED for the hidden logs page) -----------------------------
# Only this Google account can open /logs. Defaults to the address in the spec.
ADMIN_EMAIL=jhendricks0314@gmail.com

# --- Anthropic / Claude (REQUIRED for AI features) -------------------------
# Powers recipe generation, cost estimates, command validation, and receipt OCR.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# --- Twilio SMS (OPTIONAL — recipe sharing texts) --------------------------
# Without these, sharing still copies recipes between profiles but skips the SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Store lookup (OPTIONAL) ------------------------------------------------
# If set, nearby-store search uses Google Places. Without it, ForkCast falls
# back to a built-in list of common chains ranked by distance from the user.
GOOGLE_PLACES_API_KEY=

# ============================================================================
# Live price scraping (OPTIONAL — powers "Update live prices" on a list)
# ============================================================================

# --- Kroger Public API (recommended: real, reliable, free for personal use) --
# Register an app at https://developer.kroger.com/ (grant the product.compact
# scope). Covers all Kroger banners: Kroger, Fred Meyer, Ralphs, King Soopers,
# Harris Teeter, Fry's, Smith's, QFC, Dillons, and more.
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_DEFAULT_ZIP=72701          # fallback store location if none supplied

# --- Configurable HTML scrapers (add any server-rendered store) --------------
# JSON array. {term} is replaced with the URL-encoded search term. Set
# "render": true to route through SCRAPER_BROWSER_URL for JS-heavy sites.
# Example:
# SCRAPER_CONFIG=[{"id":"harps","label":"Harps","searchUrl":"https://www.harpsfood.com/search?q={term}","render":false,"selectors":{"item":".product-cell","name":".cell-title","price":".cell-price"}}]
SCRAPER_CONFIG=

# --- Headless render proxy (needed to scrape Walmart/Target/Sam's, etc.) -----
# For JS-heavy sites that block plain requests, route through a headless browser
# that runs the page's JavaScript and returns rendered HTML. Two supported shapes:
#
#  A) Browserless (easiest). Cloud or self-hosted. ForkCast POSTs { url } to the
#     /content endpoint and reads back raw HTML.
#       • Cloud:       SCRAPER_BROWSER_URL=https://production-sfo.browserless.io/content
#                      SCRAPER_BROWSER_TOKEN=your-browserless-token
#         (or put the token inline: .../content?token=your-token and leave TOKEN blank)
#       • Self-hosted: docker run -d -p 3000:3000 -e "TOKEN=your-secret" ghcr.io/browserless/chromium
#                      SCRAPER_BROWSER_URL=http://localhost:3000   (→ /content is added for you)
#                      SCRAPER_BROWSER_TOKEN=your-secret
#
#  B) Your own service. Anything that accepts POST { url } and returns either raw
#     HTML or JSON { html }. Point SCRAPER_BROWSER_URL straight at it.
#
# Must be reachable from Netlify in production (a localhost URL only works locally).
# Leave blank to use direct fetch + the Kroger API only.
SCRAPER_BROWSER_URL=
SCRAPER_BROWSER_TOKEN=
