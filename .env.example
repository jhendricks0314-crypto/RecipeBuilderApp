# ============================================================================
# ForkCast environment variables
# Copy to `.env` for local dev (`netlify dev` loads it automatically), and set
# the same keys under Site settings → Environment variables on Netlify.
# ============================================================================

# --- Session signing (REQUIRED) --------------------------------------------
# Any long random string. Generate one: `openssl rand -hex 32`
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google OAuth SSO (REQUIRED for login) ---------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
#   • OAuth consent screen: External, add the "userinfo.email" + "openid" scopes
#   • Authorized redirect URI (local):  http://localhost:8888/api/auth-google/callback
#   • Authorized redirect URI (prod):   https://YOUR-SITE.netlify.app/api/auth-google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Admin (REQUIRED for the hidden logs page) -----------------------------
# Only this Google account can open /logs. Defaults to the address in the spec.
ADMIN_EMAIL=jhendricks0314@gmail.com

# --- Anthropic / Claude (REQUIRED for AI features) -------------------------
# Powers recipe generation, cost estimates, command validation, and receipt OCR.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# --- Store lookup (OPTIONAL) ------------------------------------------------
# If set, nearby-store search uses Google Places. Without it, ForkCast falls
# back to a built-in list of common chains ranked by distance from the user.
GOOGLE_PLACES_API_KEY=

# ============================================================================
# Pricing
# ============================================================================
# ForkCast does NOT scrape retailer sites. Prices come from two places:
#   1. YOUR PRICE DATABASE — prices you record (manual entry, barcode scan, or a
#      scanned receipt). These always win: they're what you actually paid.
#   2. AI ESTIMATES — for anything you haven't priced yet, Claude estimates a
#      typical price for your ZIP code. Needs ANTHROPIC_API_KEY (set above).
#
# The ZIP lives on your profile (set it during onboarding or in Profile), so
# there is nothing to configure here.

# ============================================================================
# Emailing a shopping list (OPTIONAL)
# ============================================================================
# Lets ForkCast email a shopping list to someone, with checkboxes they can tap
# to tick items off (progress syncs back to the app — no account needed on
# their end). Get a free key at https://resend.com
#
# Without this, sharing still works: ForkCast generates the same shareable link
# and hands it to your own mail app to send.
RESEND_API_KEY=
MAIL_FROM=ForkCast <onboarding@resend.dev>
